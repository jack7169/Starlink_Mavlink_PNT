#!/bin/sh /etc/rc.common
# StarNav - Starlink to MAVLink position forwarding service

START=99
STOP=10
USE_PROCD=1

PROG=/opt/starnav/starnav.sh
CONFIG=/etc/starnav.conf

start_service() {
    procd_open_instance starnav
    procd_set_param command "$PROG"
    procd_set_param env STARNAV_CONFIG="$CONFIG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/starnav.pid
    procd_close_instance
}
